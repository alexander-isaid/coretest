<p style="color: green"><%= notice %></p>

<%= render @transaccion %>

<h3>Movimiento</h3>
<hr>
<div>
  <p>
    <strong>Saldo Anterior:</strong>
    <%= @transaccion.movimiento.saldo_anterior %>
  </p>

  <p>
    <strong>Monto:</strong>
    <%= @transaccion.movimiento.monto %>
  </p>

  <p>
    <strong>Monto Flotante:</strong>
    <%= @transaccion.movimiento.monto_flotante %>
  </p>

  <p>
    <strong>Saldo Actual:</strong>
    <%= @transaccion.movimiento.saldo_actual %>
  </p>

</div>



<div>
  <%= link_to "Edit this transaccion", edit_transaccion_path(@transaccion) %> |
  <%= link_to "Back to transacciones", transacciones_path %>

  <%= button_to "Destroy this transaccion", @transaccion, method: :delete %>
</div>
