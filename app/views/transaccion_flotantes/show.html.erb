<p style="color: green"><%= notice %></p>
<h2>Transaccion #<%= @transaccion_flotante.id %></h2>
<%= render @transaccion_flotante %>

<h3>Movimiento</h3>
<hr>
<% if @transaccion_flotante.movimiento.present? %>
  <div>
    <p>
      <strong>Saldo Anterior:</strong>
      <%= @transaccion_flotante.movimiento.saldo_anterior %>
    </p>

    <p>
      <strong>Monto:</strong>
      <%= @transaccion_flotante.movimiento.monto %>
    </p>

    <p>
      <strong>Monto Flotante:</strong>
      <%= @transaccion_flotante.movimiento.monto_flotante %>
    </p>

    <p>
      <strong>Saldo Actual:</strong>
      <%= @transaccion_flotante.movimiento.saldo_actual %>
    </p>

  </div>
<%  end %>

<div>
  <%= link_to "Edit this transaccion flotante", edit_transaccion_flotante_path(@transaccion_flotante) %> |
  <%= link_to "Back to transaccion flotantes", transaccion_flotantes_path %>

  <%= button_to "Destroy this transaccion flotante", @transaccion_flotante, method: :delete %>
</div>
