<%= form_with(model: cuenta) do |form| %>
  <% if cuenta.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(cuenta.errors.count, "error") %> prohibited this cuenta from being saved:</h2>

      <ul>
        <% cuenta.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :numero, style: "display: block" %>
    <%= form.text_field :numero %>
  </div>

  <div>
    <%= form.label :nombre, style: "display: block" %>
    <%= form.text_field :nombre %>
  </div>

  <!-- <div>
    <%= form.label :disponible, style: "display: block" %>
    <%= form.text_field :disponible %>
  </div> -->

  <div>
    <%= form.submit %>
  </div>
<% end %>
